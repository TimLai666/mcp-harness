# mcp-harness env example. Copy to .env and fill in.
# Leave OIDC vars empty for single-user/local mode (owner = "local").
# Set them to enable multi-tenant + OAuth (Logto).

# Logto issuer, including the /oidc suffix. Discovery + JWKS auto-detected.
MCP_HARNESS_OIDC_ISSUER=https://<tenant>.logto.app/oidc

# Traditional Web application in Logto (for Web UI login).
# Set its Redirect URI to <PUBLIC_URL>/auth/callback
MCP_HARNESS_OIDC_CLIENT_ID=
MCP_HARNESS_OIDC_CLIENT_SECRET=

# A Logto API Resource identifier for the MCP server. This string must match
# the Logto API identifier AND <PUBLIC_URL>/mcp exactly.
MCP_HARNESS_OIDC_AUDIENCE=https://<host>/mcp

# Public base URL of this deployment. No trailing slash.
MCP_HARNESS_PUBLIC_URL=https://<host>

# Random secret that signs the Web UI session cookie (e.g. `openssl rand -hex 32`).
MCP_HARNESS_SESSION_SECRET=

# Optional: a single shared static bearer for the /mcp endpoint, used only when
# OIDC is NOT configured. ChatGPT cannot use this; it needs OAuth (OIDC above).
# MCP_HARNESS_MCP_BEARER_TOKEN=

# Optional: set to 1 to also log accepted tokens / successful logins. Token
# REJECTIONS are always logged (with the reason, e.g. opaque token or aud
# mismatch) regardless of this flag.
# MCP_HARNESS_AUTH_DEBUG=1
